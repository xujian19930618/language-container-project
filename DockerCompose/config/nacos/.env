

# MODE(运行模式): cluster(集群)/standalone(单独)
MODE=standalone
# NACOS_SERVERS(集群地址): ip1:port1 ip2:port2 ip3:port3
# NACOS_SERVERS=
# hostname模式
# PREFER_HOST_MODE
# 端口: 8848
# NACOS_APPLICATION_PORT
# 自定义服务器地址
# NACOS_SERVER_IP
# mysql 或者 为空, 默认为空
SPRING_DATASOURCE_PLATFORM=mysql
# MySQL地址, 端口, 数据库名, 数据库账号, 密码
MYSQL_SERVICE_HOST=mysql
MYSQL_SERVICE_PORT=3306
MYSQL_SERVICE_DB_NAME=nacos_config
MYSQL_SERVICE_USER=root
MYSQL_SERVICE_PASSWORD=root
MYSQL_DATABASE_NUM=1
# URL: characterEncoding=utf8&connectTimeout=1000&socketTimeout=3000&autoReconnect=true&useSSL=false
# MYSQL_SERVICE_DB_PARAM
# -Xms:1g -Xmx:1g xmn:512M -XX:MetaspaceSize:128M -XX:MaxMetaspaceSize:320M
# JVM_XMS
# JVM_XMX
# JVM_XMN
# JVM_MS
# JVM_MMS
# 调试功能 y/n
NACOS_DEBUG=y
# tomcat日志
# TOMCAT_ACCESSLOG_ENABLED=false

# 是否使用auth系统, 目前仅支持 nacos
# NACOS_AUTH_SYSTEM_TYPE
# 是否开启鉴权: false
# NACOS_AUTH_ENABLE
# 令牌过期时间: 18000
# NACOS_AUTH_TOKEN_EXPIRE_SECONDS
# token
# NACOS_AUTH_TOKEN=SecretKey012345678901234567890123456789012345678901234567890123456789
# 打开/关闭身份验证信息的缓存。通过打开此开关，身份验证信息的更新将有 15 秒的延迟
# NACOS_AUTH_CACHE_ENABLE
# 使用配置文件或命令行参数设置群集列表
# MEMBER_LIST
# 在没有 mysql 的集群模式下使用嵌入式存储, none
# EMBEDDED_STORAGE

# NACOS_AUTH_CACHE_ENABLE=false
# NACOS_AUTH_USER_AGENT_AUTH_WHITE_ENABLE=false
# NACOS_AUTH_IDENTITY_KEY=serverIdentity
# NACOS_AUTH_IDENTITY_VALUE=security

# NACOS_SECURITY_IGNORE_URLS

