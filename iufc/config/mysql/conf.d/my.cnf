[mysqld]
log-bin=mysql-bin # 开启 binlog,二进制日志名，默认binlog /var/lib/mysql
binlog-format=ROW # 选择 ROW 模式, 设置日志格式，默认值ROW
server_id=1 # 配置 MySQL replaction 需要定义，不要和 canal 的 slaveId 重复
binlog-do-db=canal 	# 设置需要复制的数据库，默认复制全部数据库

# 设置不需要复制的数据库
# binlog-ignore-db=mysql
# binlog-ignore-db=infomation_schema
plugin-load=AUDIT=libaudit_plugin.so

